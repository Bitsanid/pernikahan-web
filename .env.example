# ============================================================
# NikahDigital - Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================
# ----------------------------------------------------------
# Appwrite Configuration (https://appwrite.io)
# Create a project at https://cloud.appwrite.io
# ----------------------------------------------------------
# Your Appwrite project endpoint (e.g. https://cloud.appwrite.io/v1)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# Your Appwrite project ID (find in Project Settings)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
# Appwrite API key (for server-side operations)
# Create in Project Settings > API Keys with the following scopes:
#   accounts.read, accounts.write, sessions.write, sessions.delete
APPWRITE_API_KEY=your_api_key_here
# ----------------------------------------------------------
# App Configuration
# ----------------------------------------------------------
# Application base URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ----------------------------------------------------------
# Auth Configuration
# ----------------------------------------------------------
# Appwrite OAuth callback base URL (same as NEXT_PUBLIC_APP_URL)
# Used as the success/failure redirect URL for OAuth providers
NEXT_PUBLIC_OAUTH_SUCCESS_URL=http://localhost:3000/dashboard
NEXT_PUBLIC_OAUTH_FAILURE_URL=http://localhost:3000/auth/login
# ----------------------------------------------------------
# Payment (Stripe) - Phase 2
# ----------------------------------------------------------
# Stripe publishable key (safe to expose in client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe secret key (never expose in client)
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# ----------------------------------------------------------
# Database (MongoDB Atlas) - Phase 2
# ----------------------------------------------------------
# MongoDB connection URI
MONGODB_URI=******cluster.mongodb.net/nikahdigital
# ----------------------------------------------------------
# Email (Optional)
# ----------------------------------------------------------
# SMTP / email service configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
