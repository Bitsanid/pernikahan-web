# ============================================================
# NikahDigital - Environment Variables Local Development
# Copy this file to .env.local and fill in your values
# ============================================================

# ----------------------------------------------------------
# Appwrite Configuration (https://appwrite.io)
# Create a project at https://cloud.appwrite.io
# ----------------------------------------------------------

# Your Appwrite project endpoint (e.g. https://cloud.appwrite.io/v1)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite project ID (find in Project Settings)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=67b6da440026e6326b4d

# Appwrite API key (for server-side operations)
# Create in Project Settings > API Keys with the following scopes:
#   accounts.read, accounts.write, sessions.write, sessions.delete, users.read, users.write
APPWRITE_API_KEY=your_api_key_here

# ----------------------------------------------------------
# App Configuration
# ----------------------------------------------------------

# Application base URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------
# Auth Configuration (Google OAuth)
# ----------------------------------------------------------

# OAuth Redirect URIs in Appwrite Console:
# Add these to your Project > Settings > Auth > Google:
#   - http://localhost:3000/api/auth/oauth/callback

# ----------------------------------------------------------
# Payment (Stripe) - Phase 2 (Optional for Auth Phase)
# ----------------------------------------------------------

# Stripe publishable key (safe to expose in client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_sample_key

# Stripe secret key (never expose in client)
STRIPE_SECRET_KEY=sk_test_sample_key

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_sample_secret

# ----------------------------------------------------------
# Database (MongoDB Atlas) - Phase 2 (Optional for Auth Phase)
# ----------------------------------------------------------

# MongoDB connection URI
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nikahdigital
